#!/bin/bash
# Don't exit on error to allow the script to continue even if grep doesn't find matches
set +e

echo "🚀 ========== PRE-COMMIT CHECKS STARTED ========== 🚀"

# Run the branch-check script
echo "🌿 Checking branch name..."
.husky/branch-check
BRANCH_CHECK_STATUS=$?
if [ $BRANCH_CHECK_STATUS -ne 0 ]; then
  echo "❌ Branch name check failed. Please fix your branch name before committing."
  exit 1
fi

# Determine changed files
echo "🔎 Scanning for changed files..."
STAGED_FILES=$(git diff --cached --name-only)

echo "$STAGED_FILES" | grep -q '^\.app/'
HAS_APP_CHANGES=$?

echo "$STAGED_FILES" | grep -q '^\.api/'
HAS_API_CHANGES=$?

if [ $HAS_APP_CHANGES -eq 0 ]; then
  echo "📱 Found changes in .app directory. Running frontend checks..."
else
  echo "💤 No changes detected in .app directory. Skipping frontend checks."
fi

if [ $HAS_API_CHANGES -eq 0 ]; then
  echo "⚙️  Found changes in .api directory. Running backend checks..."
else
  echo "💤 No changes detected in .api directory. Skipping backend checks."
fi

# Function to run a command and capture its output and status
run_command() {
  local cmd="$1"
  local label="$2"
  local output_file

  # Cross-platform temporary file creation
  if command -v mktemp >/dev/null 2>&1; then
    output_file=$(mktemp)
  else
    # Fallback for Windows
    output_file=".husky/temp_output_$RANDOM.txt"
    touch "$output_file"
  fi

  echo "🔄 Starting $label..."
  eval "$cmd" > "$output_file" 2>&1
  local status=$?

  if [ $status -ne 0 ]; then
    echo "❌ Error encountered during $label:"
    cat "$output_file"
    rm -f "$output_file"
    exit 1
  else
    echo "✅ $label passed!"
    rm -f "$output_file"
    return 0
  fi
}

# File to store process IDs
pid_file=".husky/temp_pids_$RANDOM.txt"
touch "$pid_file"

# Function to run checks based on the directory
run_checks() {
  local dir="$1"
  local is_app="$2"

  if [ "$is_app" = "true" ]; then
    # Run frontend checks
    export NODE_OPTIONS="--max-old-space-size=4096"

    # Run checks sequentially on Windows, in parallel on Unix-like systems
    if [ "$(uname -s | cut -c1-5)" = "MINGW" ] || [ "$(uname -s | cut -c1-4)" = "MSYS" ] || [ "$(uname -s | cut -c1-5)" = "CYGWI" ]; then
      # Windows - run sequentially
      run_command "pnpm lint:prettier:fix" "Prettier for frontend"
      run_command "pnpm lint:eslint:fix" "ESLint for frontend"
      run_command "pnpm test:tsc:filtered" "TypeScript compilation for frontend"
      run_command "pnpm --dir .app run test:regular" "Regular unit tests for frontend"
      run_command "pnpm --dir .app run test:utilities" "Utility unit tests for frontend"
    else
      # Unix-like systems - Prettier runs first, then others in parallel
      run_command "pnpm lint:prettier:fix" "Prettier for frontend"
      
      # Now run ESLint, TypeScript, and tests in parallel
      run_command "pnpm lint:eslint:fix" "ESLint for frontend" &
      echo $! >> "$pid_file"

      run_command "pnpm test:tsc:filtered" "TypeScript compilation for frontend" &
      echo $! >> "$pid_file"

      run_command "pnpm --dir .app run test:regular" "Regular unit tests for frontend" &
      echo $! >> "$pid_file"

      run_command "pnpm --dir .app run test:utilities" "Utility unit tests for frontend" &
      echo $! >> "$pid_file"
    fi
  else
    # Run backend checks
    if [ "$(uname -s | cut -c1-5)" = "MINGW" ] || [ "$(uname -s | cut -c1-4)" = "MSYS" ] || [ "$(uname -s | cut -c1-5)" = "CYGWI" ]; then
      # Windows - run sequentially
      run_command "pnpm format:api" "Prettier for backend"
      run_command "pnpm lint:api" "ESLint for backend"
      run_command "pnpm typecheck:api" "TypeScript compilation for backend"
      run_command "pnpm test:api" "API unit tests"
      run_command "pnpm test:api:e2e" "API E2E tests"
    else
      # Unix-like systems - Prettier runs first, then others in parallel
      run_command "pnpm format:api" "Prettier for backend"
      
      # Now run ESLint, TypeScript, and tests in parallel
      run_command "pnpm lint:api" "ESLint for backend" &
      echo $! >> "$pid_file"

      run_command "pnpm typecheck:api" "TypeScript compilation for backend" &
      echo $! >> "$pid_file"

      run_command "pnpm test:api" "API unit tests" &
      echo $! >> "$pid_file"

      run_command "pnpm test:api:e2e" "API E2E tests" &
      echo $! >> "$pid_file"
    fi
  fi
}

# Run checks based on changes
if [ $HAS_APP_CHANGES -eq 0 ]; then
  run_checks ".app" "true"
fi

if [ $HAS_API_CHANGES -eq 0 ]; then
  run_checks ".api" "false"
fi

# Wait for all background processes to complete on Unix-like systems
if [ "$(uname -s | cut -c1-5)" != "MINGW" ] && [ "$(uname -s | cut -c1-4)" != "MSYS" ] && [ "$(uname -s | cut -c1-5)" != "CYGWI" ]; then
  if [ -s "$pid_file" ]; then
    while read -r pid; do
      wait $pid || exit 1
    done < "$pid_file"
  fi
fi

# Clean up
rm -f "$pid_file"

# COMMENTED OUT: We are not automatically adding files to the commit to give developers control over what gets committed. If you want to add modified files, please do so manually after the checks pass.
# # Add only if there are changes
# if ! git diff --quiet; then
#   echo "📋 Adding modified files to the commit..."
#   git add -A
# fi

echo ""
echo "🎉 ========== ALL PRE-COMMIT CHECKS PASSED! ========== 🎉"
echo "🚀 Your code is ready to be committed! 🚀"
echo ""
