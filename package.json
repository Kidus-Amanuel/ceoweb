{
  "name": "ceo_web_project_v1",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "prepare": "husky install",
    "dev": "pnpm --filter app dev",
    "build": "pnpm --filter app build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "format": "prettier --write .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:fix": "pnpm --filter app run lint",
    "test:tsc:filtered": "pnpm --filter app exec tsc --noEmit",
    "test:regular": "pnpm --filter app run test",
    "test:utilities": "echo 'No utility tests yet' && exit 0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0"
  },
  "lint-staged": {
    ".app/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter app exec eslint --fix",
      "prettier --write"
    ],
    "**/*.{md,json}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
