RETURNS JSON
LANGUAGE sql
SECURITY DEFINER
STABLE
AS $$
  SELECT json_build_object(
    'user_id', cu.user_id,
    'company_id', cu.company_id,
    'company_name', c.name,
    'role_id', r.id,
    'role_name', r.name,
    'position', cu.position,
