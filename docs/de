-- -----------------------------------------------------
-- RLS POLICIES: role_permissions
-- -----------------------------------------------------

-- SELECT: Super admins see all, company users see their company role permissions
CREATE POLICY "RolePermissions: super_admin can view all"
  ON role_permissions FOR SELECT
  TO authenticated
  USING (
